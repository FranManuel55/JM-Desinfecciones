---
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;

const navColumns = [
  {
    title: 'Servicios',
    links: [
      { href: '#servicios', label: 'Control de Roedores' },
      { href: '#servicios', label: 'Control de Cucarachas' },
      { href: '#servicios', label: 'Pulgas y Garrapatas' },
      { href: '#servicios', label: 'Control de Chinches' },
    ],
  },
  {
    title: 'Empresa',
    links: [
      { href: '#nosotros', label: 'Nosotros' },
      { href: '#proceso', label: 'Proceso' },
      { href: '#resenas', label: 'Reseñas' },
      { href: '#faq', label: 'Preguntas frecuentes' },
    ],
  },
];
---

<footer class="relative bg-gray-950 text-white pt-16 md:pt-20 pb-8 overflow-hidden">
  <div class="absolute inset-0 opacity-[0.04] bg-grid pointer-events-none"></div>
  <div class="absolute -top-40 -right-40 w-[400px] h-[400px] rounded-full opacity-20 blur-3xl" style="background: #ef5e24;"></div>
  <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] rounded-full opacity-15 blur-3xl" style="background: #2c358c;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8 pb-12 border-b border-white/10">
      <div class="lg:col-span-5">
        <div class="flex items-center gap-3 mb-5">
          <div class="relative">
            <div class="absolute inset-0 rounded-xl blur-md opacity-60" style="background: linear-gradient(135deg, #ef5e24 0%, #2c358c 100%);"></div>
            <div class="relative w-12 h-12 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #ef5e24 0%, #2c358c 100%);">
              <span class="text-white font-display font-extrabold text-lg">JM</span>
            </div>
          </div>
          <div>
            <div class="font-display font-bold text-xl tracking-tight">{SITE_CONFIG.name}</div>
            <div class="text-[10px] uppercase tracking-[0.18em] text-white/50 font-semibold">Control profesional · Mendoza</div>
          </div>
        </div>

        <p class="text-white/60 mb-6 max-w-md text-pretty leading-relaxed">
          Soluciones profesionales en control de plagas. Protegé tu hogar o negocio con servicios de calidad garantizada y atención humana.
        </p>

        <div class="inline-flex items-center gap-3 p-3 pr-4 rounded-2xl bg-white/5 border border-white/10 mb-6">
          <div class="w-9 h-9 rounded-lg bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="leading-tight">
            <div class="text-xs text-white/60">Servicio</div>
            <div class="font-display font-bold text-white text-sm">100% garantizado por escrito</div>
          </div>
        </div>

        <div class="flex gap-3">
          <a href={SITE_CONFIG.instagram} target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 hover:border-white/20 transition-all" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-emerald-500/20 hover:border-emerald-500/40 transition-all" aria-label="WhatsApp">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          </a>
          <a href={`mailto:${SITE_CONFIG.email}`} class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 hover:border-white/20 transition-all" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>

      {navColumns.map((col) => (
        <div class="lg:col-span-2">
          <h3 class="font-display font-bold text-base text-white mb-4">{col.title}</h3>
          <ul class="space-y-2.5 text-white/60">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm hover:text-white transition-colors inline-flex items-center gap-1.5 group">
                  <span class="w-1 h-1 rounded-full bg-white/20 group-hover:bg-secondary-orange transition-colors"></span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="lg:col-span-3">
        <h3 class="font-display font-bold text-base text-white mb-4">Contacto</h3>
        <ul class="space-y-3.5 text-white/60">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm">{SITE_CONFIG.address}</span>
          </li>
          <li>
            <a href={`tel:${SITE_CONFIG.phone}`} class="flex items-start gap-3 hover:text-white transition-colors group">
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <span class="text-sm">{SITE_CONFIG.phone}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE_CONFIG.email}`} class="flex items-start gap-3 hover:text-white transition-colors break-all">
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <span class="text-sm">{SITE_CONFIG.email}</span>
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-secondary-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm">{SITE_CONFIG.hours}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-sm text-white/50">
        &copy; {new Date().getFullYear()} {SITE_CONFIG.name}. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-2 text-xs text-white/40">
        <span>Productos aprobados por SENASA</span>
        <span class="w-1 h-1 rounded-full bg-white/20"></span>
        <span>Servicio garantizado</span>
      </div>
    </div>
  </div>
</footer>
