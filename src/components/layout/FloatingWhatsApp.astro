---
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;
---

<div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
  <div id="wa-tooltip" class="opacity-0 translate-y-2 pointer-events-none transition-all duration-300 bg-white rounded-2xl shadow-card-hover px-4 py-3 max-w-[260px] border border-gray-100 relative">
    <button id="wa-tooltip-close" class="absolute -top-1.5 -right-1.5 w-6 h-6 rounded-full bg-gray-900 text-white text-xs flex items-center justify-center shadow-md hover:bg-gray-700 transition-colors" aria-label="Cerrar">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <div class="flex items-center gap-2 mb-1">
      <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
      <span class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">En línea</span>
    </div>
    <div class="text-sm text-gray-800 leading-snug">
      <strong class="font-display">¡Hola!</strong> ¿Necesitás ayuda con plagas? Escribinos y te respondemos en minutos.
    </div>
    <div class="absolute -bottom-2 right-7 w-4 h-4 bg-white border-r border-b border-gray-100 rotate-45"></div>
  </div>

  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="group relative w-16 h-16 rounded-full flex items-center justify-center shadow-card-hover focus:outline-none focus:ring-4 focus:ring-emerald-300/40"
    style="background: linear-gradient(135deg, #25D366 0%, #1ebd5a 100%);"
    aria-label="Contactar por WhatsApp"
  >
    <span class="absolute inset-0 rounded-full animate-ping opacity-30" style="background-color: #25D366;"></span>
    <span class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity blur-xl" style="background-color: #25D366;"></span>
    <svg class="relative w-8 h-8 text-white transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center border-2 border-white shadow">1</span>
  </a>
</div>

<script is:inline>
  (function () {
    const tooltip = document.getElementById('wa-tooltip');
    const close = document.getElementById('wa-tooltip-close');
    let dismissed = sessionStorage.getItem('wa-tooltip-dismissed') === '1';

    const show = () => {
      if (dismissed) return;
      tooltip.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
      tooltip.classList.add('opacity-100', 'translate-y-0');
    };
    const hide = () => {
      tooltip.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
      tooltip.classList.remove('opacity-100', 'translate-y-0');
    };

    setTimeout(show, 4500);

    close.addEventListener('click', (e) => {
      e.preventDefault();
      dismissed = true;
      sessionStorage.setItem('wa-tooltip-dismissed', '1');
      hide();
    });
  })();
</script>
