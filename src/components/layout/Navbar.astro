---
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;

const navLinks = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#proceso', label: 'Proceso' },
  { href: '#resenas', label: 'Reseñas' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div id="header-bg" class="absolute inset-0 bg-white/70 backdrop-blur-md border-b border-transparent transition-all duration-300"></div>

  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative">
          <div class="absolute inset-0 rounded-xl blur-md opacity-50 group-hover:opacity-80 transition-opacity" style="background: linear-gradient(135deg, #ef5e24 0%, #2c358c 100%);"></div>
          <div class="relative w-11 h-11 rounded-xl flex items-center justify-center shadow-sm" style="background: linear-gradient(135deg, #ef5e24 0%, #2c358c 100%);">
            <span class="text-white font-display font-extrabold text-lg tracking-tight">JM</span>
          </div>
        </div>
        <div class="hidden sm:flex flex-col leading-tight">
          <span class="font-display font-bold text-gray-900 text-base tracking-tight">JM Desinfecciones</span>
          <span class="text-[10px] uppercase tracking-[0.18em] text-gray-500 font-semibold">Control profesional</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-1 bg-white/60 backdrop-blur rounded-full px-2 py-1.5 border border-gray-200/60">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="relative px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-full transition-colors hover:bg-white"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-2">
        <a href={`tel:${SITE_CONFIG.phone}`} class="hidden md:inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold text-gray-700 hover:text-gray-900 hover:bg-gray-100 transition-colors" aria-label="Llamar">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span class="hidden xl:inline">Llamar</span>
        </a>

        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp !px-5 !py-2.5 text-sm"
          aria-label="Contactar por WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="hidden sm:inline">Presupuesto</span>
        </a>

        <button
          id="mobile-menu-toggle"
          class="lg:hidden w-11 h-11 rounded-full flex items-center justify-center text-gray-700 hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-secondary-orange/40"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg id="icon-burger" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-x-0 top-16 md:top-20 origin-top scale-y-0 opacity-0 pointer-events-none transition-all duration-300 ease-out"
    aria-hidden="true"
  >
    <div class="mx-3 mt-2 rounded-3xl bg-white border border-gray-200 shadow-2xl overflow-hidden">
      <nav class="p-3 flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="flex items-center justify-between px-4 py-3.5 rounded-2xl text-base font-medium text-gray-800 hover:bg-gray-50 transition-colors"
            data-mobile-link
          >
            <span>{link.label}</span>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        ))}
      </nav>
      <div class="p-3 pt-0 border-t border-gray-100 mt-1 grid gap-2">
        <a href={`tel:${SITE_CONFIG.phone}`} class="btn-ghost w-full !py-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Llamar ahora
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const bg = document.getElementById('header-bg');
    const onScroll = () => {
      if (window.scrollY > 16) {
        bg.classList.add('bg-white/95', 'shadow-sm', 'border-gray-200');
        bg.classList.remove('bg-white/70', 'border-transparent');
      } else {
        bg.classList.remove('bg-white/95', 'shadow-sm', 'border-gray-200');
        bg.classList.add('bg-white/70', 'border-transparent');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconBurger = document.getElementById('icon-burger');
    const iconClose = document.getElementById('icon-close');
    let open = false;
    const setOpen = (v) => {
      open = v;
      toggle.setAttribute('aria-expanded', String(v));
      menu.setAttribute('aria-hidden', String(!v));
      menu.classList.toggle('scale-y-0', !v);
      menu.classList.toggle('opacity-0', !v);
      menu.classList.toggle('pointer-events-none', !v);
      menu.classList.toggle('scale-y-100', v);
      menu.classList.toggle('opacity-100', v);
      iconBurger.classList.toggle('hidden', v);
      iconClose.classList.toggle('hidden', !v);
      document.body.style.overflow = v ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => setOpen(!open));
    document.querySelectorAll('[data-mobile-link]').forEach((l) => l.addEventListener('click', () => setOpen(false)));
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && open) setOpen(false);
    });
  })();
</script>
