---
interface Props {
  name: 'sprayer' | 'gloves' | 'mask' | 'trap' | 'inspection' | 'certificate' | 'biohazard' | 'spray-can';
  class?: string;
  color?: string;
}

const { name, class: className = 'w-7 h-7', color = 'currentColor' } = Astro.props;
---

{name === 'sprayer' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M14 4h5l-2 4h-3z"/>
    <path d="M14 8v3"/>
    <path d="M11 11h6a1 1 0 011 1v8a1 1 0 01-1 1h-6a1 1 0 01-1-1v-8a1 1 0 011-1z"/>
    <path d="M10 14H5a2 2 0 00-2 2v1"/>
    <path d="M3 17v2a1 1 0 001 1h2"/>
    <path d="M14 15h0M14 18h0"/>
  </svg>
)}

{name === 'spray-can' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M9 7h6v13a1 1 0 01-1 1h-4a1 1 0 01-1-1V7z"/>
    <path d="M10 7V4a1 1 0 011-1h2a1 1 0 011 1v3"/>
    <path d="M18 5h2M18 8h2M18 11h2"/>
    <circle cx="12" cy="13" r="1.4"/>
  </svg>
)}

{name === 'gloves' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M7 21v-7a2 2 0 012-2h6a2 2 0 012 2v7"/>
    <path d="M9 12V6.5a1.5 1.5 0 113 0V11"/>
    <path d="M12 11V5.5a1.5 1.5 0 113 0V11"/>
    <path d="M15 11V7.5a1.5 1.5 0 113 0V12c0 2-1 3-2 4"/>
    <path d="M9 12V8.5a1.5 1.5 0 10-3 0V12c0 2 1 3 2 4"/>
  </svg>
)}

{name === 'mask' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 9c0-1 1-2 2-2h12c1 0 2 1 2 2v3c0 4-3 7-8 7s-8-3-8-7V9z"/>
    <path d="M4 11H2M22 11h-2"/>
    <path d="M9 12h6"/>
    <path d="M9 15h6"/>
  </svg>
)}

{name === 'trap' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="14" width="18" height="6" rx="1"/>
    <path d="M5 14V8a2 2 0 012-2h10a2 2 0 012 2v6"/>
    <path d="M9 14V9a1 1 0 011-1h4a1 1 0 011 1v5"/>
    <circle cx="12" cy="11" r="1"/>
  </svg>
)}

{name === 'inspection' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="10" cy="10" r="6"/>
    <path d="M14.5 14.5L20 20"/>
    <path d="M10 7v6M7 10h6"/>
  </svg>
)}

{name === 'certificate' && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="4" width="18" height="13" rx="1"/>
    <path d="M3 9h18"/>
    <path d="M9 13h6"/>
    <circle cx="12" cy="20" r="2" fill={color}/>
    <path d="M10 18l-2 3M14 18l2 3"/>
  </svg>
)}

{name === 'biohazard' && (
  <svg class={className} viewBox="0 0 24 24" fill={color} aria-hidden="true">
    <path d="M12 13.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/>
    <path d="M12 9.5c-.4 0-.8.1-1.1.2L8.3 5.6c-.3-.5-.1-1.1.4-1.4 1-.4 2.1-.7 3.3-.7s2.3.2 3.3.7c.5.2.7.9.4 1.4l-2.6 4.1c-.3-.1-.7-.2-1.1-.2z"/>
    <path d="M8.3 11.5l-4.7-.2c-.5 0-.9-.5-.8-1 .3-2.1 1.2-4 2.6-5.5.4-.4 1-.3 1.3.2L9.4 9c-.5.7-.9 1.5-1.1 2.5z"/>
    <path d="M15.7 11.5c-.2-1-.6-1.8-1.1-2.5l2.6-4c.3-.5.9-.6 1.3-.2 1.4 1.5 2.4 3.4 2.6 5.5.1.5-.3.9-.8 1l-4.6.2z"/>
    <path d="M10.9 14.7l-2.7 4.1c-.3.5-1 .5-1.4.1-1.6-1.4-2.7-3.3-3-5.4-.1-.5.3-1 .9-1l4.7-.2c.3 1 .8 1.7 1.5 2.4z"/>
    <path d="M13.1 14.7c.7-.7 1.2-1.4 1.5-2.4l4.7.2c.5 0 1 .5.9 1-.3 2.1-1.4 4-3 5.4-.4.4-1.1.4-1.4-.1l-2.7-4.1z"/>
  </svg>
)}
