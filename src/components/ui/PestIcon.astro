---
interface Props {
  name: 'rat' | 'cockroach' | 'bedbug' | 'flea' | 'tick' | 'ant' | 'mosquito' | 'spider';
  class?: string;
  color?: string;
}

const { name, class: className = 'w-10 h-10', color = 'currentColor' } = Astro.props;
---

{/*
  Pest silhouettes — detailed enough to be recognizable at small sizes (24px+).
  All paths use currentColor or the passed `color` prop so they tint cleanly.
*/}

{name === 'rat' && (
  <svg class={className} viewBox="0 0 64 64" fill={color} aria-hidden="true">
    {/* Long tail (drawn first, behind body) */}
    <path d="M14 42 C 6 42 2 46 2 52 C 2 56 4 56 5 54 C 6 51 9 49 12 49 C 16 49 19 47 19 43 Z" />
    {/* Body */}
    <ellipse cx="28" cy="40" rx="17" ry="13" />
    {/* Hind leg */}
    <ellipse cx="22" cy="52" rx="5" ry="3" />
    {/* Front paw */}
    <ellipse cx="40" cy="52" rx="4" ry="2.5" />
    {/* Head */}
    <ellipse cx="46" cy="34" rx="10" ry="9" />
    {/* Snout */}
    <path d="M54 32 C 60 30 62 34 60 38 C 58 41 53 40 53 37 Z" />
    {/* Ear */}
    <circle cx="44" cy="24" r="5" />
    <circle cx="44" cy="24" r="2.4" fill="#fff" fill-opacity="0.25" />
    {/* Eye */}
    <circle cx="50" cy="33" r="1.6" fill="#fff" />
    {/* Whiskers */}
    <line x1="56" y1="36" x2="62" y2="34" stroke={color} stroke-width="0.8" />
    <line x1="56" y1="38" x2="62" y2="40" stroke={color} stroke-width="0.8" />
  </svg>
)}

{name === 'cockroach' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* Antennae */}
    <path d="M27 13 C 22 8 16 4 10 3" stroke={color} stroke-width="2" fill="none" stroke-linecap="round" />
    <path d="M37 13 C 42 8 48 4 54 3" stroke={color} stroke-width="2" fill="none" stroke-linecap="round" />
    {/* Legs left */}
    <path d="M19 22 L 8 18 L 4 14" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M17 32 L 4 32" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M19 42 L 8 48 L 6 54" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Legs right */}
    <path d="M45 22 L 56 18 L 60 14" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M47 32 L 60 32" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M45 42 L 56 48 L 58 54" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Body (oval) */}
    <ellipse cx="32" cy="34" rx="14" ry="20" fill={color} />
    {/* Head (smaller, on top) */}
    <ellipse cx="32" cy="16" rx="9" ry="6" fill={color} />
    {/* Wing center line */}
    <line x1="32" y1="20" x2="32" y2="50" stroke="#fff" stroke-width="1.2" stroke-opacity="0.45" />
    {/* Wing texture */}
    <path d="M22 24 Q 28 32 22 44" stroke="#fff" stroke-width="0.8" stroke-opacity="0.3" fill="none" />
    <path d="M42 24 Q 36 32 42 44" stroke="#fff" stroke-width="0.8" stroke-opacity="0.3" fill="none" />
    {/* Eyes */}
    <circle cx="28" cy="15" r="1.4" fill="#fff" />
    <circle cx="36" cy="15" r="1.4" fill="#fff" />
  </svg>
)}

{name === 'bedbug' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* Antennae */}
    <path d="M27 13 L 20 6" stroke={color} stroke-width="2" fill="none" stroke-linecap="round" />
    <path d="M37 13 L 44 6" stroke={color} stroke-width="2" fill="none" stroke-linecap="round" />
    {/* Legs left (6 short) */}
    <path d="M15 22 L 6 18" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M13 32 L 3 32" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M15 42 L 6 46" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    {/* Legs right */}
    <path d="M49 22 L 58 18" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M51 32 L 61 32" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M49 42 L 58 46" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    {/* Flat oval body */}
    <ellipse cx="32" cy="34" rx="19" ry="15" fill={color} />
    {/* Head */}
    <ellipse cx="32" cy="17" rx="7" ry="5" fill={color} />
    {/* Body segments */}
    <path d="M14 28 Q 32 30 50 28" stroke="#fff" stroke-width="1" stroke-opacity="0.4" fill="none" />
    <path d="M14 34 Q 32 36 50 34" stroke="#fff" stroke-width="1" stroke-opacity="0.4" fill="none" />
    <path d="M14 40 Q 32 42 50 40" stroke="#fff" stroke-width="1" stroke-opacity="0.4" fill="none" />
    {/* Eyes */}
    <circle cx="29" cy="16" r="1.2" fill="#fff" />
    <circle cx="35" cy="16" r="1.2" fill="#fff" />
  </svg>
)}

{name === 'flea' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* Body — arched/curled flea shape */}
    <path d="M 18 38 C 16 22 30 14 42 22 C 50 28 50 42 42 50 C 32 54 22 50 18 38 Z" fill={color} />
    {/* Head bump */}
    <circle cx="22" cy="30" r="7" fill={color} />
    {/* Eye */}
    <circle cx="22" cy="29" r="1.8" fill="#fff" />
    {/* Mouth/proboscis (downward) */}
    <path d="M 16 34 L 8 38" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Front leg */}
    <path d="M 26 46 L 22 58 L 26 60" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Middle leg */}
    <path d="M 34 50 L 34 60" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Big jumping rear leg (the famous flea jumping leg) */}
    <path d="M 44 44 L 56 30 L 56 42 L 50 58" stroke={color} stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    {/* Antenna */}
    <path d="M 22 22 L 16 14" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    {/* Bristles on back */}
    <line x1="38" y1="20" x2="38" y2="14" stroke={color} stroke-width="1.2" />
    <line x1="44" y1="22" x2="46" y2="16" stroke={color} stroke-width="1.2" />
  </svg>
)}

{name === 'tick' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* 8 legs (4 each side) */}
    <path d="M 17 22 L 6 14" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 14 32 L 2 32" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 16 40 L 4 46" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 20 46 L 12 56" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 47 22 L 58 14" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 50 32 L 62 32" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 48 40 L 60 46" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 44 46 L 52 56" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Engorged round body */}
    <circle cx="32" cy="36" r="18" fill={color} />
    {/* Highlight on body (glossy) */}
    <ellipse cx="26" cy="30" rx="5" ry="3" fill="#fff" fill-opacity="0.25" />
    {/* Small head/capitulum on front */}
    <path d="M 28 18 Q 32 12 36 18 L 34 22 L 30 22 Z" fill={color} />
    {/* Mouth parts pointing forward */}
    <line x1="32" y1="10" x2="32" y2="4" stroke={color} stroke-width="1.4" stroke-linecap="round" />
    <line x1="30" y1="11" x2="28" y2="6" stroke={color} stroke-width="1.2" stroke-linecap="round" />
    <line x1="34" y1="11" x2="36" y2="6" stroke={color} stroke-width="1.2" stroke-linecap="round" />
  </svg>
)}

{name === 'ant' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* Antennae */}
    <path d="M 10 22 Q 4 14 2 6" stroke={color} stroke-width="1.8" fill="none" stroke-linecap="round" />
    <path d="M 14 20 Q 12 10 14 4" stroke={color} stroke-width="1.8" fill="none" stroke-linecap="round" />
    {/* Legs (6 from thorax — left and right) */}
    <path d="M 26 30 L 14 18 L 12 12" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M 28 34 L 18 36" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M 26 38 L 16 50 L 14 56" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M 32 30 L 36 18 L 38 12" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M 34 34 L 44 36" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    <path d="M 32 38 L 38 50 L 40 56" stroke={color} stroke-width="2.2" fill="none" stroke-linecap="round" />
    {/* Head */}
    <ellipse cx="14" cy="24" rx="8" ry="7" fill={color} />
    {/* Mandibles */}
    <path d="M 8 18 L 4 14" stroke={color} stroke-width="1.4" stroke-linecap="round" />
    <path d="M 8 20 L 4 18" stroke={color} stroke-width="1.4" stroke-linecap="round" />
    {/* Thorax (middle) */}
    <ellipse cx="29" cy="34" rx="6" ry="6" fill={color} />
    {/* Petiole (narrow waist) */}
    <ellipse cx="22" cy="30" rx="2.5" ry="2" fill={color} />
    <ellipse cx="36" cy="34" rx="2" ry="1.6" fill={color} />
    {/* Abdomen (gaster) */}
    <ellipse cx="48" cy="38" rx="12" ry="10" fill={color} />
    {/* Eye */}
    <circle cx="11" cy="22" r="1.6" fill="#fff" />
    {/* Abdomen highlight */}
    <ellipse cx="44" cy="34" rx="3" ry="2" fill="#fff" fill-opacity="0.2" />
  </svg>
)}

{name === 'mosquito' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* Wings (translucent) */}
    <ellipse cx="18" cy="26" rx="14" ry="6" transform="rotate(-30 18 26)" fill={color} fill-opacity="0.35" />
    <ellipse cx="46" cy="26" rx="14" ry="6" transform="rotate(30 46 26)" fill={color} fill-opacity="0.35" />
    {/* Wing veins */}
    <path d="M 8 22 Q 18 28 28 22" stroke={color} stroke-width="0.6" fill="none" stroke-opacity="0.5" />
    <path d="M 36 22 Q 46 28 56 22" stroke={color} stroke-width="0.6" fill="none" stroke-opacity="0.5" />
    {/* Long legs (6) */}
    <path d="M 30 38 L 14 30 L 8 24" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    <path d="M 30 42 L 10 44 L 4 50" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    <path d="M 30 46 L 18 56 L 22 62" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    <path d="M 34 38 L 50 30 L 56 24" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    <path d="M 34 42 L 54 44 L 60 50" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    <path d="M 34 46 L 46 56 L 42 62" stroke={color} stroke-width="1.6" fill="none" stroke-linecap="round" />
    {/* Body (slim elongated) */}
    <path d="M 28 22 Q 32 18 36 22 L 35 50 Q 32 54 29 50 Z" fill={color} />
    {/* Head */}
    <circle cx="32" cy="20" r="5" fill={color} />
    {/* Long proboscis (needle mouth) */}
    <line x1="32" y1="15" x2="32" y2="2" stroke={color} stroke-width="1.8" stroke-linecap="round" />
    {/* Antennae */}
    <path d="M 28 16 Q 22 10 22 6" stroke={color} stroke-width="1" fill="none" stroke-linecap="round" />
    <path d="M 36 16 Q 42 10 42 6" stroke={color} stroke-width="1" fill="none" stroke-linecap="round" />
    {/* Eyes */}
    <circle cx="29" cy="19" r="1.4" fill="#fff" />
    <circle cx="35" cy="19" r="1.4" fill="#fff" />
  </svg>
)}

{name === 'spider' && (
  <svg class={className} viewBox="0 0 64 64" aria-hidden="true">
    {/* 8 legs — curved, going outward */}
    <path d="M 24 22 Q 14 14 4 10" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 23 28 Q 10 26 2 26" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 24 34 Q 14 38 6 42" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 26 40 Q 20 50 16 60" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 40 22 Q 50 14 60 10" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 41 28 Q 54 26 62 26" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 40 34 Q 50 38 58 42" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    <path d="M 38 40 Q 44 50 48 60" stroke={color} stroke-width="2.4" fill="none" stroke-linecap="round" />
    {/* Abdomen (round body) */}
    <ellipse cx="32" cy="38" rx="13" ry="14" fill={color} />
    {/* Cephalothorax (head) */}
    <ellipse cx="32" cy="22" rx="9" ry="7" fill={color} />
    {/* Eyes (cluster of 4) */}
    <circle cx="28" cy="20" r="1.5" fill="#fff" />
    <circle cx="36" cy="20" r="1.5" fill="#fff" />
    <circle cx="30" cy="24" r="1" fill="#fff" />
    <circle cx="34" cy="24" r="1" fill="#fff" />
    {/* Body marking (classic spider X/star) */}
    <path d="M 32 32 L 32 44 M 26 38 L 38 38" stroke="#fff" stroke-width="1" stroke-opacity="0.3" />
    {/* Fangs */}
    <line x1="30" y1="27" x2="29" y2="30" stroke={color} stroke-width="1.4" />
    <line x1="34" y1="27" x2="35" y2="30" stroke={color} stroke-width="1.4" />
  </svg>
)}
