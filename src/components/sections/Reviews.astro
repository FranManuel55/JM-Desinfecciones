---
import Container from '@/components/ui/Container.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '@/data/siteConfig';

const reviews = await getCollection('reviews');
const sortedReviews = reviews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-AR', { year: 'numeric', month: 'short' });
}

function getInitials(name: string): string {
  return name
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((n) => n[0].toUpperCase())
    .join('');
}

const avatarGradients = [
  'from-orange-400 to-red-500',
  'from-blue-400 to-indigo-600',
  'from-emerald-400 to-teal-600',
  'from-fuchsia-400 to-purple-600',
  'from-amber-400 to-orange-600',
  'from-cyan-400 to-blue-600',
];

const marqueeReviews = [...sortedReviews, ...sortedReviews];
const googleMapsUrl = 'https://www.google.com/maps/place/JM+Desinfecciones';
---

<section id="resenas" class="relative py-12 md:py-16 overflow-hidden bg-gradient-to-b from-white to-gray-50/80">
  <Container>
    <div class="text-center mb-8 md:mb-10 max-w-3xl mx-auto">
      <span class="reveal chip bg-amber-50 text-amber-700">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
        Reseñas reales
      </span>
      <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-5 mb-5 text-balance tracking-tightest">
        Lo que dicen quienes <span class="text-gradient-brand">nos eligen</span>
      </h2>

      <div class="reveal reveal-delay-2 inline-flex items-center gap-3 px-5 py-3 rounded-full bg-white border border-gray-200 shadow-soft">
        <svg class="w-7 h-7" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        <div class="flex items-center gap-1 text-amber-400 text-xl">
          {[0,1,2,3,4].map(() => (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
          ))}
        </div>
        <div class="text-sm">
          <span class="font-display font-bold text-gray-900">{SITE_CONFIG.socialRating}</span>
          <span class="text-gray-500"> · </span>
          <span class="font-medium text-gray-700">{SITE_CONFIG.socialReviewCount} reseñas</span>
        </div>
      </div>
    </div>

    <div class="reveal reveal-delay-3 relative marquee-mask overflow-hidden">
      <div class="flex gap-5 animate-marquee pause-on-hover w-max">
        {marqueeReviews.map((review, i) => (
          <article class="w-[320px] md:w-[360px] flex-shrink-0 bg-white rounded-3xl p-6 md:p-7 border border-gray-100 shadow-soft hover:shadow-card-hover transition-shadow flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${avatarGradients[i % avatarGradients.length]} flex items-center justify-center text-white font-display font-bold shadow-md`}>
                  {getInitials(review.data.name)}
                </div>
                <div class="leading-tight">
                  <div class="font-display font-bold text-gray-900">{review.data.name}</div>
                  <div class="text-xs text-gray-500 mt-0.5">{formatDate(review.data.date)}</div>
                </div>
              </div>
              <svg class="w-6 h-6 flex-shrink-0" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            </div>

            <div class="flex items-center gap-0.5 text-amber-400 mb-3">
              {Array.from({ length: review.data.rating }).map(() => (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
              ))}
            </div>

            <p class="text-gray-700 text-[15px] leading-relaxed line-clamp-5 flex-1">"{review.data.text}"</p>
          </article>
        ))}
      </div>
    </div>

    <div class="text-center mt-12">
      <a
        href={googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm font-semibold text-gray-700 bg-white border border-gray-200 hover:border-gray-900 hover:text-gray-900 transition-all hover:-translate-y-0.5 shadow-soft"
      >
        Ver todas las reseñas en Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </Container>
</section>
