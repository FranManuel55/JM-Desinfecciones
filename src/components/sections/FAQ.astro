---
import Container from '@/components/ui/Container.astro';
import { getCollection, render } from 'astro:content';
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const faqs = await getCollection('faq');
const sortedFaqs = faqs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const faqsWithContent = await Promise.all(
  sortedFaqs.map(async (faq) => {
    const { Content } = await render(faq);
    return { ...faq, Content };
  })
);

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.contact)}`;
---

<section id="faq" class="relative py-12 md:py-16 overflow-hidden bg-gray-50/80">
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full opacity-[0.05] blur-3xl" style="background: #2c358c;"></div>

  <Container>
    <div class="grid lg:grid-cols-[1fr_1.5fr] gap-10 lg:gap-16 items-start">
      <div class="lg:sticky lg:top-28">
        <span class="reveal chip bg-secondary-orange-light text-secondary-orange">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"/></svg>
          Preguntas frecuentes
        </span>

        <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-5 mb-5 leading-[1.1] tracking-tightest text-balance">
          Resolvemos tus <span class="text-gradient-brand">dudas</span>
        </h2>

        <p class="reveal reveal-delay-2 text-lg text-gray-600 mb-8 text-pretty">
          Recopilamos las consultas más comunes sobre nuestros servicios de control de plagas. ¿Tu pregunta no está acá?
        </p>

        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="reveal reveal-delay-3 inline-flex items-center gap-3 p-4 pr-5 rounded-2xl bg-white border border-gray-200 hover:border-secondary-orange hover:shadow-soft transition-all group">
          <div class="w-11 h-11 rounded-xl bg-emerald-500 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          </div>
          <div class="text-left">
            <div class="font-display font-bold text-gray-900">Hablar con un asesor</div>
            <div class="text-sm text-gray-500">Respondemos en 24 horas</div>
          </div>
          <svg class="w-5 h-5 ml-2 text-gray-400 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="reveal reveal-delay-2 space-y-3" id="faq-list">
        {faqsWithContent.map((faq, index) => (
          <details
            class="faq-item group bg-white rounded-2xl border border-gray-100 shadow-soft hover:border-gray-200 open:border-secondary-orange/40 open:shadow-card-hover transition-all duration-300"
            open={index === 0}
          >
            <summary class="px-6 py-5 flex items-center justify-between gap-4 cursor-pointer list-none transition-colors">
              <div class="flex items-start gap-4 flex-1 min-w-0">
                <span class="flex-shrink-0 mt-0.5 w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold font-display transition-colors bg-gray-100 text-gray-500 group-hover:bg-gray-200 group-open:bg-secondary-orange group-open:text-white" aria-hidden="true">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="font-display font-bold text-gray-900 text-base md:text-lg leading-snug">
                  {faq.data.question}
                </span>
              </div>
              <div class="faq-chevron flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 bg-gray-100 text-gray-600 group-hover:bg-gray-200 group-open:bg-secondary-orange group-open:text-white">
                <svg class="w-4 h-4 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <div class="faq-body px-6 pb-6 pl-[68px] text-gray-600 leading-relaxed text-[15px]">
              <faq.Content />
            </div>
          </details>
        ))}
      </div>
    </div>
  </Container>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sortedFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.data.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.body
    }
  }))
})}></script>

<script is:inline>
  (function () {
    const list = document.getElementById('faq-list');
    if (!list) return;
    const items = list.querySelectorAll('.faq-item');
    items.forEach((item) => {
      item.addEventListener('toggle', (e) => {
        if (item.open) {
          items.forEach((other) => {
            if (other !== item && other.open) other.open = false;
          });
        }
      });
    });
  })();
</script>

<style>
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary { user-select: none; }

  .faq-item[open] .faq-body {
    animation: faq-expand 0.4s ease-out;
  }

  @keyframes faq-expand {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
