---
import Container from '@/components/ui/Container.astro';
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.contact)}`;

const contactItems = [
  {
    label: 'Ubicación',
    value: SITE_CONFIG.address,
    icon: 'pin',
    href: null,
    accent: 'orange',
  },
  {
    label: 'Teléfono · WhatsApp',
    value: SITE_CONFIG.phone,
    icon: 'phone',
    href: `tel:${SITE_CONFIG.phone}`,
    accent: 'blue',
  },
  {
    label: 'Email',
    value: SITE_CONFIG.email,
    icon: 'mail',
    href: `mailto:${SITE_CONFIG.email}`,
    accent: 'orange',
  },
  {
    label: 'Horario de atención',
    value: SITE_CONFIG.hours,
    icon: 'clock',
    href: null,
    accent: 'blue',
  },
];

const accentMap = {
  orange: { bg: '#fef3e8', icon: '#ef5e24' },
  blue: { bg: '#e8eaf6', icon: '#2c358c' },
};

const iconPaths = {
  pin: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  phone: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  mail: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<section id="contacto" class="relative py-12 md:py-16 overflow-hidden">
  <Container>
    <div class="text-center mb-8 md:mb-10 max-w-3xl mx-auto">
      <span class="reveal chip bg-secondary-orange-light text-secondary-orange">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        Contacto
      </span>
      <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-5 mb-4 text-balance tracking-tightest">
        Estamos para <span class="text-gradient-brand">ayudarte</span>
      </h2>
      <p class="reveal reveal-delay-2 text-lg text-gray-600 text-pretty">
        Contactanos por el canal que prefieras. Te respondemos en menos de 24 horas y evaluamos tu caso sin compromiso.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      <div class="reveal space-y-6">
        <div class="grid sm:grid-cols-2 gap-4">
          {contactItems.map((item) => {
            const a = accentMap[item.accent];
            const content = (
              <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-soft hover:shadow-card-hover transition-all hover-lift h-full">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-3" style={`background-color: ${a.bg};`}>
                  <svg class="w-5 h-5" fill="none" stroke={a.icon} viewBox="0 0 24 24" stroke-width="2">
                    {item.icon === 'pin' ? (
                      <>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </>
                    ) : (
                      <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon]} />
                    )}
                  </svg>
                </div>
                <p class="text-[11px] uppercase tracking-wider text-gray-500 font-semibold mb-1">{item.label}</p>
                <p class="font-display font-semibold text-gray-900 text-sm leading-snug">{item.value}</p>
              </div>
            );
            return item.href ? (
              <a href={item.href} class="block">{content}</a>
            ) : content;
          })}
        </div>

        <div class="bg-white rounded-3xl p-6 md:p-7 border border-gray-100 shadow-soft">
          <div class="flex items-start gap-3 mb-4">
            <div class="w-11 h-11 rounded-xl bg-emerald-500 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-gray-900">Respuesta inmediata por WhatsApp</h3>
              <p class="text-sm text-gray-600 mt-0.5">Es la vía más rápida para contactarnos.</p>
            </div>
          </div>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            Escribir por WhatsApp
          </a>
          <div class="grid grid-cols-3 gap-3 mt-5 pt-5 border-t border-gray-100 text-center">
            <div>
              <div class="font-display text-lg font-bold text-gray-900">24h</div>
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Respuesta</div>
            </div>
            <div>
              <div class="font-display text-lg font-bold text-gray-900">Lun-Sab</div>
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Horario</div>
            </div>
            <div>
              <div class="font-display text-lg font-bold text-gray-900">Gratis</div>
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Evaluación</div>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2 relative">
        <div class="absolute -inset-3 bg-brand-gradient rounded-3xl opacity-10 blur-2xl"></div>
        <div class="relative rounded-3xl overflow-hidden border border-gray-100 shadow-card-hover h-[420px] lg:h-full min-h-[420px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3348.876416!2d-68.845678!3d-32.889458!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x1234567890abcdef!2sMendoza%2C%20Argentina!5e0!3m2!1ses-419!2sar!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de JM Desinfecciones en Mendoza"
          ></iframe>

          <div class="absolute top-4 left-4 bg-white rounded-2xl p-3 pr-5 shadow-card-hover flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #ef5e24 0%, #2c358c 100%);">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Sede principal</div>
              <div class="font-display font-bold text-gray-900 text-sm leading-tight">Ciudad de Mendoza</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
