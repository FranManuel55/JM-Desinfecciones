---
import Container from '@/components/ui/Container.astro';
import EquipIcon from '@/components/ui/EquipIcon.astro';
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.contact)}`;

const steps = [
  {
    number: '01',
    title: 'Contactanos',
    description: 'Escribinos por WhatsApp o llamanos. Te respondemos en menos de 24 horas para coordinar.',
    time: 'Rápido',
    iconClass: 'icon-phone',
    type: 'phone',
  },
  {
    number: '02',
    title: 'Inspección técnica',
    description: 'Visitamos tu propiedad para identificar focos y determinar el tratamiento adecuado.',
    time: 'Sin cargo',
    iconClass: 'icon-magnify',
    type: 'inspection',
  },
  {
    number: '03',
    title: 'Fumigación',
    description: 'Aplicamos el tratamiento con equipamiento profesional y productos habilitados por SENASA.',
    time: 'Mismo día',
    iconClass: 'icon-spray',
    type: 'sprayer',
  },
  {
    number: '04',
    title: 'Garantía',
    description: 'Te entregamos certificado del servicio y te acompañamos hasta confirmar la eliminación.',
    time: 'Garantizado',
    iconClass: 'icon-cert',
    type: 'certificate',
  },
];
---

<section id="proceso" class="relative py-12 md:py-16 overflow-hidden" style="background: linear-gradient(135deg, #1a1f5c 0%, #2c358c 50%, #1a1f5c 100%);">
  <div class="absolute inset-0 opacity-10 bg-dot"></div>
  <div class="absolute top-0 right-0 w-[480px] h-[480px] rounded-full opacity-25 blur-3xl animate-blob" style="background: #ef5e24;"></div>
  <div class="absolute bottom-0 left-0 w-[480px] h-[480px] rounded-full opacity-15 blur-3xl animate-blob" style="background: #ef5e24; animation-delay: -4s;"></div>

  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-[20%] left-[10%] w-2 h-2 rounded-full bg-white/30 animate-float"></div>
    <div class="absolute top-[60%] left-[80%] w-1.5 h-1.5 rounded-full bg-secondary-orange/40 animate-float" style="animation-delay: -2s;"></div>
    <div class="absolute top-[80%] left-[30%] w-1 h-1 rounded-full bg-white/40 animate-float" style="animation-delay: -4s;"></div>
    <div class="absolute top-[15%] left-[70%] w-1.5 h-1.5 rounded-full bg-white/20 animate-float-slow"></div>
  </div>

  <Container>
    <div class="relative text-center mb-10 md:mb-12 max-w-3xl mx-auto">
      <span class="reveal chip glass-dark text-white">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Cómo trabajamos
      </span>
      <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mt-5 mb-4 text-balance tracking-tightest">
        Un proceso simple,
        <span class="relative inline-block">
          <span style="background: linear-gradient(135deg, #ff8a5b 0%, #ef5e24 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">resultados garantizados</span>
          <svg class="absolute -bottom-2 left-0 w-full h-2.5" viewBox="0 0 200 12" fill="none" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 8 C 60 2, 140 2, 198 8" stroke="#ef5e24" stroke-width="3" stroke-linecap="round" stroke-dasharray="200" stroke-dashoffset="200" style="animation: draw-line 1.8s 0.6s ease-out forwards;"/>
          </svg>
        </span>
      </h2>
      <p class="reveal reveal-delay-2 text-lg text-white/75 text-pretty">
        Del primer contacto a la garantía. Trabajamos de forma ordenada para que tu experiencia sea impecable.
      </p>
    </div>

    <div class="relative" id="process-grid">
      <svg class="hidden lg:block absolute top-[70px] left-0 right-0 w-full h-3 pointer-events-none" viewBox="0 0 100 1" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <linearGradient id="connector-grad" x1="0" x2="100%" y1="0" y2="0">
            <stop offset="0%" stop-color="#ef5e24" stop-opacity="0.7"/>
            <stop offset="50%" stop-color="#ffffff" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#ef5e24" stop-opacity="0.7"/>
          </linearGradient>
        </defs>
        <line x1="12" y1="0.5" x2="88" y2="0.5" stroke="url(#connector-grad)" stroke-width="0.4" stroke-dasharray="2 2"/>
      </svg>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
        {steps.map((step, i) => (
          <div
            class={`process-card reveal reveal-delay-${(i % 4) + 1} relative group`}
            data-step={i}
          >
            <div class="step-glow absolute -inset-1 rounded-3xl blur-2xl opacity-0 transition-opacity duration-500 pointer-events-none" style="background: linear-gradient(135deg, #ef5e24, #ff8a5b);"></div>

            <div class="relative glass-dark rounded-3xl p-6 md:p-7 h-full transition-all duration-500 group-hover:bg-white/15 group-hover:-translate-y-1.5 group-hover:border-white/30 overflow-hidden">
              <div class="absolute -top-2 -right-3 font-display text-[110px] leading-none font-extrabold process-step-number select-none pointer-events-none">
                {step.number}
              </div>

              <div class="relative flex items-start justify-between mb-6">
                <div class="relative">
                  <div class="step-badge-glow absolute inset-0 rounded-2xl blur-md opacity-50" style="background: linear-gradient(135deg, #ef5e24, #d54d18);"></div>
                  <div class="step-badge relative w-14 h-14 rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, #ef5e24, #d54d18);">
                    {step.type === 'phone' && (
                      <svg class={`w-7 h-7 text-white ${step.iconClass} origin-center`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                    )}
                    {step.type === 'inspection' && (
                      <EquipIcon name="inspection" color="#ffffff" class={`w-7 h-7 ${step.iconClass} origin-center`} />
                    )}
                    {step.type === 'sprayer' && (
                      <EquipIcon name="sprayer" color="#ffffff" class={`w-7 h-7 ${step.iconClass} origin-center`} />
                    )}
                    {step.type === 'certificate' && (
                      <EquipIcon name="certificate" color="#ffffff" class={`w-7 h-7 ${step.iconClass} origin-center`} />
                    )}
                  </div>
                </div>
              </div>

              <div class="relative">
                <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/10 text-[10px] uppercase tracking-wider font-bold text-white/90 mb-3 border border-white/10">
                  <span class="relative flex w-1.5 h-1.5">
                    <span class="absolute inline-flex w-full h-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span>
                    <span class="relative inline-flex w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                  </span>
                  {step.time}
                </div>

                <h3 class="font-display text-xl font-bold text-white mb-2 tracking-tight">{step.title}</h3>
                <p class="text-white/70 text-[15px] leading-relaxed">{step.description}</p>
              </div>

              <div class="absolute bottom-0 left-0 right-0 h-1 overflow-hidden rounded-b-3xl">
                <div class="step-progress h-full w-full origin-left scale-x-0 transition-transform duration-700" style="background: linear-gradient(90deg, #ef5e24, #ff8a5b, #ef5e24);"></div>
              </div>
            </div>

            {i < steps.length - 1 && (
              <div class="hidden lg:flex absolute top-[72px] -right-3 w-6 h-6 items-center justify-center z-20 pointer-events-none">
                <div class="relative w-6 h-6 rounded-full glass-dark flex items-center justify-center">
                  <svg class="w-3 h-3 text-white/80 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="reveal mt-10 text-center">
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp text-base !py-4 !px-8">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
        Comenzar ahora
      </a>
      <p class="text-sm text-white/60 mt-4">Respondemos en menos de 24 horas · Evaluación sin cargo</p>
    </div>
  </Container>
</section>

<script is:inline>
  (function () {
    const grid = document.getElementById('process-grid');
    if (!grid) return;
    const cards = grid.querySelectorAll('.process-card');
    if (!cards.length) return;

    let activeIndex = -1;
    let paused = false;
    let timer = null;

    const setActive = (i) => {
      cards.forEach((c, idx) => {
        const isActive = idx === i;
        c.classList.toggle('is-active', isActive);
        const progress = c.querySelector('.step-progress');
        if (progress) {
          progress.style.transform = isActive ? 'scaleX(1)' : 'scaleX(0)';
        }
      });
    };

    const tick = () => {
      if (paused) return;
      activeIndex = (activeIndex + 1) % cards.length;
      setActive(activeIndex);
    };

    const start = () => {
      if (timer) return;
      timer = window.setInterval(tick, 2200);
    };
    const stop = () => {
      if (!timer) return;
      window.clearInterval(timer);
      timer = null;
    };

    cards.forEach((c, idx) => {
      c.addEventListener('mouseenter', () => {
        paused = true;
        activeIndex = idx;
        setActive(idx);
      });
      c.addEventListener('mouseleave', () => {
        paused = false;
      });
    });

    if ('IntersectionObserver' in window) {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              if (activeIndex === -1) {
                activeIndex = 0;
                setActive(0);
              }
              start();
            } else {
              stop();
            }
          });
        },
        { threshold: 0.2 }
      );
      obs.observe(grid);
    } else {
      setActive(0);
      start();
    }
  })();
</script>
