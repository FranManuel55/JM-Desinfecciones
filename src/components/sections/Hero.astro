---
import Container from '@/components/ui/Container.astro';
import PestIcon from '@/components/ui/PestIcon.astro';
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.services)}`;

const heroPests = [
  { label: 'Roedores', icon: 'rat' as const },
  { label: 'Cucarachas', icon: 'cockroach' as const },
  { label: 'Chinches', icon: 'bedbug' as const },
  { label: 'Pulgas', icon: 'flea' as const },
  { label: 'Garrapatas', icon: 'tick' as const },
  { label: 'Hormigas', icon: 'ant' as const },
];
---

<section class="relative pt-24 pb-12 md:pt-32 md:pb-16 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-grid bg-grid-fade"></div>
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-32 -right-24 w-[480px] h-[480px] rounded-full opacity-30 blur-3xl animate-blob" style="background: radial-gradient(circle, #ef5e24 0%, transparent 70%);"></div>
    <div class="absolute -bottom-32 -left-24 w-[480px] h-[480px] rounded-full opacity-30 blur-3xl animate-blob" style="background: radial-gradient(circle, #2c358c 0%, transparent 70%); animation-delay: -4s;"></div>
  </div>

  <Container>
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <div class="reveal inline-flex items-center gap-2 pl-1.5 pr-4 py-1.5 rounded-full bg-white border border-gray-200 shadow-soft mb-7">
          <span class="flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider text-white" style="background: linear-gradient(135deg, #ef5e24, #d54d18);">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
            Top
          </span>
          <span class="text-sm text-gray-700 font-medium">Control profesional de plagas en Mendoza</span>
        </div>

        <h1 class="reveal reveal-delay-1 font-display text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-gray-900 leading-[1.05] tracking-tightest mb-6 text-balance">
          Recuperá la tranquilidad de tu
          <span class="relative inline-block">
            <span class="text-gradient-brand">hogar</span>
            <svg class="absolute -bottom-2 left-0 w-full h-3" viewBox="0 0 200 12" fill="none" preserveAspectRatio="none">
              <path d="M2 10 C 50 2, 150 2, 198 10" stroke="url(#underline)" stroke-width="4" stroke-linecap="round"/>
              <defs>
                <linearGradient id="underline" x1="0" x2="200" y1="0" y2="0">
                  <stop stop-color="#ef5e24"/>
                  <stop offset="1" stop-color="#2c358c"/>
                </linearGradient>
              </defs>
            </svg>
          </span>
          <br />sin plagas, sin riesgos
        </h1>

        <p class="reveal reveal-delay-2 text-lg md:text-xl text-gray-600 mb-8 max-w-xl mx-auto lg:mx-0 text-pretty">
          Eliminamos roedores, cucarachas, chinches, pulgas y garrapatas con productos certificados por SENASA. <strong class="font-semibold text-gray-900">Garantía escrita</strong> y atención en 24 horas.
        </p>

        <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start mb-10">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp text-base !py-4">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Presupuesto gratis
          </a>
          <a href="#servicios" class="btn-ghost text-base !py-4">
            Ver servicios
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>

        <div class="reveal reveal-delay-4 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-sm text-gray-600">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Garantía escrita
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Productos SENASA
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Sin compromiso
          </div>
        </div>

        <div class="reveal reveal-delay-5 grid grid-cols-3 gap-4 mt-10 pt-8 border-t border-gray-200/80 max-w-lg mx-auto lg:mx-0">
          <div>
            <div class="font-display text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tightest">
              <span data-counter="500" data-suffix="+">0+</span>
            </div>
            <div class="text-xs md:text-sm text-gray-500 mt-1">Clientes atendidos</div>
          </div>
          <div>
            <div class="font-display text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tightest">
              <span data-counter="98" data-suffix="%">0%</span>
            </div>
            <div class="text-xs md:text-sm text-gray-500 mt-1">Satisfacción</div>
          </div>
          <div>
            <div class="font-display text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tightest flex items-baseline gap-1">
              <span data-counter="4.8" data-decimals="1">0</span>
              <svg class="w-5 h-5 text-amber-400 self-center" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
            </div>
            <div class="text-xs md:text-sm text-gray-500 mt-1">Rating Google</div>
          </div>
        </div>
      </div>

      <div class="relative reveal reveal-delay-2">
        <div class="absolute -inset-6 bg-brand-gradient rounded-[2.5rem] blur-3xl opacity-15 animate-pulse-slow"></div>

        <div class="relative">
          {/*
            ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
            FOTO DEL HERO
            ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
            Para usar una foto real:
              1. Pegá la imagen en /public/hero-team.jpg (1000x1200 aprox)
              2. Reemplazá el bloque <!-- PLACEHOLDER --> por:
                 <img
                   src="/hero-team.jpg"
                   alt="Equipo de JM Desinfecciones"
                   class="absolute inset-0 w-full h-full object-cover"
                   loading="eager"
                 />
            ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
          */}
          <div class="relative aspect-[4/5] rounded-[2rem] overflow-hidden border border-gray-200 shadow-card-hover bg-white">
            {/* PLACEHOLDER — empieza */}
            <div class="absolute inset-0" style="background: linear-gradient(140deg, #1a1f5c 0%, #2c358c 60%, #3a4ab8 100%);"></div>
            <div class="absolute inset-0 opacity-15 bg-dot"></div>
            <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full opacity-30 blur-3xl" style="background: #ef5e24;"></div>
            <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full opacity-20 blur-3xl" style="background: #ef5e24;"></div>

            <div class="relative h-full flex flex-col items-center justify-center text-center px-8">
              <div class="relative mb-5">
                <div class="absolute -inset-2 rounded-3xl blur-xl opacity-40 bg-white"></div>
                <div class="relative w-20 h-20 rounded-3xl bg-white/10 backdrop-blur border border-white/20 flex items-center justify-center">
                  <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
              </div>

              <div class="font-display text-white text-xl font-bold tracking-tight mb-1.5">Espacio para tu foto</div>
              <p class="text-white/60 text-sm max-w-[240px] leading-relaxed mb-5">
                Equipo de trabajo, mochila pulverizadora, técnico en acción o camioneta de la empresa.
              </p>

              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-dark">
                <svg class="w-3.5 h-3.5 text-amber-300" fill="currentColor" viewBox="0 0 24 24"><path d="M9 2L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3.17L15 2H9zm3 15c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5z"/></svg>
                <span class="text-[10px] uppercase tracking-wider font-bold text-white/90">1000 × 1200 px</span>
              </div>

              <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold">
                Hero.astro · línea 117
              </div>
            </div>
            {/* PLACEHOLDER — termina */}
          </div>

          <div class="absolute -bottom-5 -left-5 hidden md:flex items-center gap-3 bg-white rounded-2xl px-4 py-3 shadow-card-hover animate-float" style="animation-delay: -2s;">
            <div class="flex -space-x-2">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">MG</div>
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">JP</div>
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 border-2 border-white flex items-center justify-center text-white text-xs font-bold">LR</div>
            </div>
            <div class="leading-tight">
              <div class="flex items-center gap-0.5 text-amber-400">
                {[0,1,2,3,4].map(() => (
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
                ))}
              </div>
              <div class="text-[11px] font-semibold text-gray-900">+127 reseñas</div>
            </div>
          </div>

          <div class="absolute -top-5 -right-5 hidden md:flex items-center gap-2 bg-white rounded-2xl px-4 py-3 shadow-card-hover animate-float-slow">
            <div class="relative w-10 h-10 rounded-xl flex items-center justify-center bg-emerald-50 border border-emerald-100">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-500 border-2 border-white animate-pulse"></span>
            </div>
            <div class="leading-tight">
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Aprobado</div>
              <div class="text-sm font-bold text-gray-900">SENASA</div>
            </div>
          </div>

          <div class="absolute top-1/2 -right-3 -translate-y-1/2 hidden lg:flex flex-col items-center gap-2 bg-white rounded-2xl px-3 py-4 shadow-card-hover animate-float" style="animation-delay: -3s;">
            <div class="font-display font-extrabold text-2xl text-gradient-brand">10+</div>
            <div class="text-[9px] uppercase tracking-wider text-gray-500 font-semibold leading-tight text-center max-w-[60px]">Años en el rubro</div>
          </div>
        </div>
      </div>
    </div>

    <div class="reveal reveal-delay-6 mt-10 md:mt-12 pt-8 border-t border-gray-200/80">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.18em] text-gray-400 mb-5">
        Especialistas en eliminar
      </p>
      <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
        {heroPests.map((p) => (
          <span class="group inline-flex items-center gap-2 pl-2 pr-4 py-1.5 rounded-full bg-white border border-gray-200 text-sm font-medium text-gray-700 hover:border-secondary-orange hover:text-secondary-orange hover:-translate-y-0.5 transition-all shadow-soft">
            <span class="w-7 h-7 rounded-full bg-gray-100 group-hover:bg-secondary-orange-light flex items-center justify-center transition-colors">
              <PestIcon name={p.icon} color="#4b5563" class="w-4 h-4 group-hover:text-secondary-orange" />
            </span>
            {p.label}
          </span>
        ))}
      </div>
    </div>
  </Container>
</section>
