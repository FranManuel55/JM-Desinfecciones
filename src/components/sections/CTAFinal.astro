---
import Container from '@/components/ui/Container.astro';
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '@/data/siteConfig';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.quote)}`;
---

<section class="relative py-12 md:py-16 overflow-hidden">
  <div class="absolute inset-0 -z-10 animate-gradient" style="background: linear-gradient(135deg, #ef5e24 0%, #2c358c 50%, #ef5e24 100%);"></div>
  <div class="absolute inset-0 -z-10 opacity-20 bg-dot"></div>
  <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full opacity-30 blur-3xl animate-float" style="background: #ff8a5b;"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 rounded-full opacity-30 blur-3xl animate-float-slow" style="background: #5b67d6;"></div>

  <Container>
    <div class="relative max-w-4xl mx-auto text-center">
      <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass-dark mb-6">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-white/90 text-xs font-bold uppercase tracking-widest">Atención inmediata</span>
      </div>

      <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 text-balance leading-[1.05] tracking-tightest">
        ¿Tenés plagas?<br/>
        <span class="text-white/90">Recuperá tu tranquilidad <span class="underline decoration-white/50 decoration-4 underline-offset-8">hoy</span></span>
      </h2>

      <p class="reveal reveal-delay-2 text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto text-pretty">
        No esperes a que el problema se agrave. Contactanos ahora y te ayudamos a recuperar la tranquilidad de tu hogar o negocio.
      </p>

      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 px-10 py-5 rounded-full text-lg font-bold transition-all hover:scale-105 shadow-2xl bg-white text-gray-900 hover:bg-gray-50">
          <svg class="w-6 h-6" fill="#25D366" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Presupuesto gratis
        </a>
        <a href={`tel:${SITE_CONFIG.phone}`} class="inline-flex items-center justify-center gap-3 px-10 py-5 rounded-full text-lg font-bold border-2 border-white/40 text-white hover:bg-white/10 backdrop-blur transition-all">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Llamar ahora
        </a>
      </div>

      <div class="reveal reveal-delay-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-white/80">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Respuesta en menos de 24h
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Sin compromiso
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Evaluación gratuita
        </div>
      </div>
    </div>
  </Container>
</section>
