---
import Container from '@/components/ui/Container.astro';

const features = [
  {
    icon: 'shield',
    title: 'Garantía escrita',
    description: 'Todos nuestros servicios incluyen garantía. Si el problema persiste, volvemos sin costo adicional.',
    accent: 'orange',
  },
  {
    icon: 'clock',
    title: 'Respuesta en 24h',
    description: 'Contactanos y te respondemos en menos de 24 horas. Servicio disponible de lunes a sábado.',
    accent: 'blue',
  },
  {
    icon: 'award',
    title: 'Técnicos certificados',
    description: 'Profesionales capacitados con años de experiencia en control integrado de plagas.',
    accent: 'orange',
  },
  {
    icon: 'leaf',
    title: 'Productos seguros',
    description: 'Productos de grado profesional aprobados por SENASA, seguros para tu familia y mascotas.',
    accent: 'green',
  },
  {
    icon: 'dollar',
    title: 'Presupuesto transparente',
    description: 'Sin costos ocultos ni sorpresas. Conocés el precio exacto antes de comenzar el trabajo.',
    accent: 'blue',
  },
  {
    icon: 'pin',
    title: 'Cobertura en Mendoza',
    description: 'Llegamos a toda la provincia: Ciudad, Gran Mendoza, Maipú, Godoy Cruz y zonas aledañas.',
    accent: 'orange',
  },
];

const accentStyles = {
  orange: { bg: '#fef3e8', icon: '#ef5e24', ring: 'rgba(239, 94, 36, 0.18)' },
  blue: { bg: '#e8eaf6', icon: '#2c358c', ring: 'rgba(44, 53, 140, 0.18)' },
  green: { bg: '#dcfce7', icon: '#059669', ring: 'rgba(5, 150, 105, 0.18)' },
};

const iconPaths = {
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  award: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  leaf: 'M3 21c3-3 5-7 5-11 0-3 2-6 6-7 3-1 7-1 7 4 0 6-5 11-10 13-3 1-6 2-8 1zm0 0l9-9',
  dollar: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  pin: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
};
---

<section class="relative py-12 md:py-16 bg-gradient-to-b from-white to-gray-50/80 overflow-hidden">
  <div class="absolute top-20 right-0 w-72 h-72 rounded-full opacity-[0.07] blur-3xl" style="background: #ef5e24;"></div>
  <div class="absolute bottom-20 left-0 w-72 h-72 rounded-full opacity-[0.07] blur-3xl" style="background: #2c358c;"></div>

  <Container>
    <div class="text-center mb-10 md:mb-12 max-w-3xl mx-auto">
      <span class="reveal chip bg-secondary-orange-light text-secondary-orange">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.5 5.79 21l2.39-7.15L2 9.36h7.61z"/></svg>
        Por qué elegirnos
      </span>
      <h2 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-5 mb-4 text-balance tracking-tightest">
        Los detalles que <span class="text-gradient-brand">marcan la diferencia</span>
      </h2>
      <p class="reveal reveal-delay-2 text-lg text-gray-600 text-pretty">
        Más de 500 clientes confían en nosotros por nuestro compromiso con la calidad, la seguridad y el servicio post-venta.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {features.map((feature, i) => {
        const a = accentStyles[feature.accent];
        return (
          <div class={`reveal reveal-delay-${(i % 3) + 1} group relative bg-white rounded-3xl p-7 md:p-8 border border-gray-100 hover-lift hover:shadow-card-hover transition-all`}>
            <div
              class="absolute -inset-px rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
              style={`background: linear-gradient(135deg, ${a.ring} 0%, transparent 60%);`}
              aria-hidden="true"
            ></div>

            <div class="relative">
              <div class="flex items-center justify-between mb-6">
                <div
                  class="w-14 h-14 rounded-2xl flex items-center justify-center transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3"
                  style={`background-color: ${a.bg};`}
                >
                  <svg class="w-7 h-7" fill="none" stroke={a.icon} viewBox="0 0 24 24" stroke-width="2">
                    {feature.icon === 'pin' ? (
                      <>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </>
                    ) : (
                      <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[feature.icon]} />
                    )}
                  </svg>
                </div>
                <span class="font-display text-xs font-bold text-gray-300 tracking-tighter">0{i + 1}</span>
              </div>
              <h3 class="font-display text-xl font-bold text-gray-900 mb-2 tracking-tight">{feature.title}</h3>
              <p class="text-gray-600 leading-relaxed text-[15px]">{feature.description}</p>
            </div>
          </div>
        );
      })}
    </div>
  </Container>
</section>
